{
  "name": "consenthub-saas",
  "version": "0.1.0",
  "private": true,
  "description": "ConsentHub SaaS MVP API",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
