  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "prisma": "6.6.0",
    "supertest": "^7.0.0"
  }
}
