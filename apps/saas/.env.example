PORT=8787
APP_ROLE=web
API_KEYS=dev-key-change-me
# Legacy full-access API keys toggle.
# Keep false by default. Enable only for short local migration windows.
ALLOW_LEGACY_API_KEYS=false
# Optional: per-site scoped credentials. Format: key|site|scope1,scope2;key2|site2|scope1
# Scopes: ingest,read,export,shops
# Recommended for production: store scoped credentials in DB (ApiCredential model)
# and use API_SITE_KEYS only as bootstrap/temporary fallback.
API_SITE_KEYS=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consenthub?schema=public
ADMIN_EMAILS=admin@consenthub.local
# Optional dashboard access policies (email|role|site1,site2;email2|role|*)
# Roles: admin, operator, billing_manager, analyst
DASHBOARD_ACCESS_POLICIES=
# Optional trusted-header SSO bridge (reverse proxy / IdP gateway)
# If enabled, configure at least one secret: DASHBOARD_SSO_HEADER_SECRET or DASHBOARD_SSO_JWT_SECRET.
DASHBOARD_SSO_ENABLED=false
DASHBOARD_SSO_HEADER_SECRET=
DASHBOARD_SSO_HEADER_EMAIL=x-sso-email
DASHBOARD_SSO_HEADER_SITES=x-sso-sites
DASHBOARD_SSO_HEADER_JWT=x-sso-jwt
# Optional dedicated JWT secret for SSO token verification (HS256).
# If omitted, falls back to DASHBOARD_SSO_HEADER_SECRET.
DASHBOARD_SSO_JWT_SECRET=
# Native enterprise OIDC (authorization code flow)
DASHBOARD_OIDC_ENABLED=false
DASHBOARD_OIDC_ISSUER=
# Optional override. Defaults to <issuer>/.well-known/openid-configuration
DASHBOARD_OIDC_DISCOVERY_URL=
DASHBOARD_OIDC_CLIENT_ID=
DASHBOARD_OIDC_CLIENT_SECRET=
# Optional override. Defaults to <APP_BASE_URL>/auth/oidc/callback
DASHBOARD_OIDC_REDIRECT_URI=
# Recommended: openid email profile
DASHBOARD_OIDC_SCOPES=openid email profile
SESSION_SECRET=change-me-super-secret
APP_BASE_URL=http://localhost:8787
SECURE_COOKIES=false
# Production: comma-separated exact origins allowed to call API from browsers.
# Example: https://demo.com,https://www.demo.com
CORS_ALLOWED_ORIGINS=
RETENTION_JOB_MINUTES=60
BILLING_ALERT_JOB_MINUTES=1440
BILLING_CRITICAL_EMAIL_COOLDOWN_MINUTES=180
RESEND_API_KEY=
EMAIL_FROM=ConsentHub <noreply@tu-dominio.com>
SUPPORT_EMAIL=soporte@tu-dominio.com
# Default ISO-like country code for consent events when payload omits country
DEFAULT_COUNTRY_CODE=CL
# Require explicit onboarding before accepting consent events for a site.
# Recommended true in production.
REQUIRE_SHOP_ONBOARDING=false
# Optional shared secret for onboarding endpoints (/onboarding/*)
ONBOARDING_SECRET=
# Temporary bypass for ownerEmail-domain validation during onboarding
ALLOW_ONBOARDING_EMAIL_DOMAIN_BYPASS=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Optional readiness strict mode: if true, /readyz and /health fail when Stripe config is missing.
READINESS_CHECK_STRIPE=false
# Max time for DB readiness probe before failing as timeout.
READINESS_DB_TIMEOUT_MS=1500
# Max time for Stripe readiness probe before failing as timeout.
READINESS_STRIPE_TIMEOUT_MS=1500
# Rate limit for dashboard audit endpoints (/dashboard/audit-logs and .csv)
# If omitted, defaults are environment-aware:
# - production: max 10 requests / 60s
# - development/test: max 60 requests / 60s
# AUDIT_LOGS_RATE_LIMIT_WINDOW_MS=60000
# AUDIT_LOGS_RATE_LIMIT_MAX=10
# Enable Prometheus metrics endpoint GET /metrics
METRICS_ENABLED=true
# Bearer token to protect /metrics (Authorization: Bearer <token>).
# Required in production when METRICS_ENABLED=true.
METRICS_BEARER_TOKEN=
# Optional comma-separated IP allowlist for /metrics (e.g. 10.0.0.10,10.0.0.11)
METRICS_ALLOWED_IPS=
# Backup retention in days for *.dump files under BACKUP_DIR (0 disables pruning)
BACKUP_RETENTION_DAYS=14
# Optional passphrase to encrypt backup artifacts (*.dump.enc)
BACKUP_ENCRYPTION_PASSPHRASE=
# Optional key identifier used for auditability when encryption is enabled
BACKUP_ENCRYPTION_KEY_ID=
# Last rotation timestamp for encryption key metadata (ISO8601 recommended)
BACKUP_ENCRYPTION_KEY_ROTATED_AT=
# Maximum allowed age (days) for backup encryption key metadata
BACKUP_KEY_MAX_AGE_DAYS=90
# Enforce strict backup secret policy (recommended true in production)
# - requires BACKUP_ENCRYPTION_PASSPHRASE
# - requires minimum passphrase length (16)
# - requires BACKUP_ENCRYPTION_KEY_ID
STRICT_BACKUP_SECRETS=false
# Optional offsite destination for backup and checksum copy.
# - Local path example: /mnt/backups-offsite
# - S3 example: s3://my-consenthub-backups/prod
OFFSITE_URI=
# Require encrypted backups before offsite copy (recommended true in production)
REQUIRE_ENCRYPTED_OFFSITE=false
# Optional dedicated URI for cloud offsite smoke workflow (s3://bucket/prefix)
OFFSITE_SMOKE_URI=
# Require backup checksum verification on restore (recommended true)
REQUIRE_BACKUP_CHECKSUM=true
BILLING_GRACE_DAYS=7
